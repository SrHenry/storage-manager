{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "module": "commonjs",
        "moduleResolution": "bundler",
        "outDir": "./dist/cjs",
        "declaration": false,
        "sourceMap": true,
        "noEmitOnError": true
    },
    "exclude": ["node_modules", "dist", "types", "**/*.spec.*", "**/*.test.*"]
}
